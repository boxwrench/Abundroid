# Copy this file to .env for a local deployment and fill in credentials.
# Never commit .env. Scheduled deployments should use their secret store.

# --- Airtable (optional) ---
# Without both values, Abundroid uses local CSV files:
#   abundroid collect: data/sources.csv -> output/items.csv
# Create a token at https://airtable.com/create/tokens with
# data.records:read and data.records:write, restricted to this base.
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=

# Unified publication-monitoring tables (defaults shown).
# Only uncomment a value when the Airtable table has a different name.
#AIRTABLE_ORGS_TABLE=Organizations
#AIRTABLE_SOURCES_TABLE=Sources
#AIRTABLE_ITEMS_TABLE=Items
#AIRTABLE_TOPICS_TABLE=Topics
#AIRTABLE_SOURCE_RUNS_TABLE=Source Runs
