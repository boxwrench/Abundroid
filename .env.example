# Copy this file to .env and fill in your own credentials.
# Abundroid never ships with credentials — each deployment (e.g. the
# Abundance Network) supplies its own.

# --- Airtable (optional) ---
# Without these, Abundroid runs in local CSV mode: organizations are read
# from data/organizations.csv and events are written to output/events.csv.
# Create a personal access token at https://airtable.com/create/tokens
# with data.records:read and data.records:write scopes on your base.
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=

# Table names inside the base (defaults shown; only set to override)
#AIRTABLE_ORGS_TABLE=Organizations
#AIRTABLE_EVENTS_TABLE=Events
#AIRTABLE_TOPICS_TABLE=Topics

# --- AI extraction (optional, Phase 4 — not used yet) ---
#ANTHROPIC_API_KEY=
